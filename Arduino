#include <DHT.h>
#include <Wire.h>
#include <LiquidCrystal_I2C.h>

#define DHTPIN 2
#define DHTTYPE DHT22

DHT dht(DHTPIN, DHTTYPE);

LiquidCrystal_I2C lcd(0x27, 16, 2);

int pirPin = 3;
int gasPin = A0;

int ledGreen = 8;
int ledYellow = 9;
int ledRed = 10;

int buzzer = 11;

void setup() {

  pinMode(pirPin, INPUT);

  pinMode(ledGreen, OUTPUT);
  pinMode(ledYellow, OUTPUT);
  pinMode(ledRed, OUTPUT);

  pinMode(buzzer, OUTPUT);

  lcd.init();
  lcd.backlight();

  dht.begin();

  Serial.begin(9600);

  lcd.setCursor(0,0);
  lcd.print("LUNA CORE");
  delay(3000);
}

void loop() {

  float temp = dht.readTemperature();

  int motion = digitalRead(pirPin);

  int gasValue = analogRead(gasPin);

  digitalWrite(ledGreen, LOW);
  digitalWrite(ledYellow, LOW);
  digitalWrite(ledRed, LOW);

  noTone(buzzer);

  // TELA PRINCIPAL
  lcd.clear();

  lcd.setCursor(0,0);
  lcd.print("Temp:");
  lcd.print(temp);
  lcd.print("C");

  if(temp <= 30){

    digitalWrite(ledGreen, HIGH);

    lcd.setCursor(0,1);
    lcd.print("STATUS OK");

  } else if(temp > 30 && temp <= 40){

    digitalWrite(ledYellow, HIGH);

    lcd.setCursor(0,1);
    lcd.print("ATENCAO");

  } else {

    digitalWrite(ledRed, HIGH);

    tone(buzzer, 1000);

    lcd.setCursor(0,1);
    lcd.print("EMERGENCIA");
  }

  delay(4000);

  // TELA GAS
  lcd.clear();

  lcd.setCursor(0,0);
  lcd.print("Gas:");
  lcd.print(gasValue);

  if(gasValue > 400){

    digitalWrite(ledRed, HIGH);

    tone(buzzer, 1500);

    lcd.setCursor(0,1);
    lcd.print("RISCO CRITICO");

  } else {

    lcd.setCursor(0,1);
    lcd.print("AR LIMPO");
  }

  delay(4000);

  // TELA MOVIMENTO
  lcd.clear();

  lcd.setCursor(0,0);
  lcd.print("Movimento:");

  if(motion == HIGH){

    lcd.setCursor(0,1);
    lcd.print("DETECTADO");

    Serial.println("Movimento detectado");

  } else {

    lcd.setCursor(0,1);
    lcd.print("NORMAL");
  }

  delay(4000);
}
